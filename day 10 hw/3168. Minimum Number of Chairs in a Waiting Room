class Solution {
    public int minimumChairs(String s) {
        int currentPeople = 0;
        int maxChairs = 0;
        
        for (int i = 0; i < s.length(); i++) {
            if (s.charAt(i) == 'E') {
                currentPeople++;
            } else {
                currentPeople--;
            }
            maxChairs = Math.max(maxChairs, currentPeople);
        }
        
        return maxChairs;
    }
}
